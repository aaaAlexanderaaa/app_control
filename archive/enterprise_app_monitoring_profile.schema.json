{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./enterprise_app_monitoring_profile.schema.json",
  "title": "Enterprise App Monitoring Profile",
  "type": "object",
  "required": [
    "$schema",
    "profile_version",
    "generated_at",
    "goal",
    "source_catalog",
    "monitoring_fields",
    "policy_tiers",
    "category_defaults",
    "summary",
    "apps"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "profile_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date"
    },
    "goal": {
      "type": "string"
    },
    "source_catalog": {
      "type": "object",
      "required": [
        "path",
        "schema_version",
        "generated_at",
        "app_count",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "schema_version": {
          "type": "string"
        },
        "generated_at": {
          "type": "string",
          "format": "date"
        },
        "app_count": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "monitoring_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "dns.query",
          "tls.sni",
          "http.hostname"
        ]
      }
    },
    "policy_tiers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policyTier"
      }
    },
    "category_defaults": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/categoryDefault"
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total_apps",
        "counts_by_policy_tier",
        "counts_by_primary_action",
        "counts_by_category",
        "apps_with_host_artifacts",
        "apps_with_high_precision_network_signals",
        "apps_requiring_network_only_or_custom_inventory"
      ],
      "properties": {
        "total_apps": {
          "type": "integer",
          "minimum": 0
        },
        "counts_by_policy_tier": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "counts_by_primary_action": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "counts_by_category": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "apps_with_host_artifacts": {
          "type": "integer",
          "minimum": 0
        },
        "apps_with_high_precision_network_signals": {
          "type": "integer",
          "minimum": 0
        },
        "apps_requiring_network_only_or_custom_inventory": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "apps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/app"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "policyTier": {
      "type": "object",
      "required": [
        "id",
        "name",
        "description",
        "default_jamf_action",
        "default_network_action"
      ],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "block_preferred",
            "managed_only",
            "monitor_high_risk"
          ]
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "default_jamf_action": {
          "type": "string"
        },
        "default_network_action": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "categoryDefault": {
      "type": "object",
      "required": [
        "category",
        "policy_tier",
        "reason"
      ],
      "properties": {
        "category": {
          "type": "string"
        },
        "policy_tier": {
          "type": "string",
          "enum": [
            "block_preferred",
            "managed_only",
            "monitor_high_risk"
          ]
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "hostArtifact": {
      "type": "object",
      "required": [
        "value",
        "match",
        "precision",
        "verification_status"
      ],
      "properties": {
        "value": {
          "type": "string"
        },
        "match": {
          "type": "string"
        },
        "precision": {
          "type": "string"
        },
        "verification_status": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "pathHostArtifact": {
      "allOf": [
        {
          "$ref": "#/$defs/hostArtifact"
        },
        {
          "type": "object",
          "required": [
            "path_type"
          ],
          "properties": {
            "path_type": {
              "type": "string",
              "enum": [
                "app_bundle",
                "cli_binary",
                "config_file",
                "credential_dir",
                "credential_file",
                "database_file",
                "env_file",
                "install_dir",
                "log_file",
                "memory_file",
                "model_dir",
                "model_file",
                "persona_file",
                "secret_file",
                "shell_completion",
                "skins_dir",
                "skills_dir",
                "state_dir",
                "workspace_dir"
              ]
            }
          }
        }
      ]
    },
    "hostnamePattern": {
      "type": "object",
      "required": [
        "pattern",
        "match",
        "match_on",
        "role",
        "precision",
        "weight",
        "verification_status"
      ],
      "properties": {
        "pattern": {
          "type": "string"
        },
        "match": {
          "type": "string"
        },
        "match_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "role": {
          "type": "string"
        },
        "precision": {
          "type": "string"
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "verification_status": {
          "type": "string"
        },
        "file_semantics": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "keywordPattern": {
      "type": "object",
      "required": [
        "pattern",
        "match",
        "precision",
        "weight"
      ],
      "properties": {
        "pattern": {
          "type": "string"
        },
        "match": {
          "type": "string"
        },
        "precision": {
          "type": "string"
        },
        "weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "app": {
      "type": "object",
      "required": [
        "catalog_app_id",
        "name",
        "category",
        "product_shape",
        "product_type",
        "severity",
        "priority_score",
        "policy_tier",
        "policy_reason",
        "jamf_posture",
        "monitoring_strategy",
        "risks",
        "risk_titles",
        "evidence_status",
        "notes"
      ],
      "properties": {
        "catalog_app_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "product_shape": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "web",
              "macos"
            ]
          }
        },
        "product_type": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "severity": {
          "type": "string"
        },
        "priority_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "policy_tier": {
          "type": "string",
          "enum": [
            "block_preferred",
            "managed_only",
            "monitor_high_risk"
          ]
        },
        "policy_reason": {
          "type": "string"
        },
        "jamf_posture": {
          "type": "object",
          "required": [
            "scope",
            "primary_action",
            "coverage",
            "host_indicators"
          ],
          "properties": {
            "scope": {
              "type": "string"
            },
            "primary_action": {
              "type": "string"
            },
            "coverage": {
              "type": "string"
            },
            "host_indicators": {
              "type": "object",
              "required": [
                "bundle_ids",
                "process_names",
                "team_ids",
                "directory_paths",
                "chrome_extension_ids",
                "safari_extension_bundle_ids",
                "notes",
                "host_signal_status"
              ],
              "properties": {
                "bundle_ids": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/hostArtifact"
                  }
                },
                "process_names": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/hostArtifact"
                  }
                },
                "team_ids": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/hostArtifact"
                  }
                },
                "directory_paths": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/pathHostArtifact"
                  }
                },
                "chrome_extension_ids": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/hostArtifact"
                  }
                },
                "safari_extension_bundle_ids": {
                  "type": "array",
                  "items": {
                    "$ref": "#/$defs/hostArtifact"
                  }
                },
                "notes": {
                  "type": "string"
                },
                "host_signal_status": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "monitoring_strategy": {
          "type": "object",
          "required": [
            "fields",
            "priority_hostname_patterns",
            "keyword_patterns",
            "signal_coverage",
            "notes"
          ],
          "properties": {
            "fields": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "dns.query",
                  "tls.sni",
                  "http.hostname"
                ]
              }
            },
            "priority_hostname_patterns": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/hostnamePattern"
              }
            },
            "keyword_patterns": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/keywordPattern"
              }
            },
            "signal_coverage": {
              "type": "object",
              "required": [
                "hostname_patterns",
                "keyword_patterns",
                "high_precision_hostname_patterns",
                "host_artifacts"
              ],
              "properties": {
                "hostname_patterns": {
                  "type": "integer",
                  "minimum": 0
                },
                "keyword_patterns": {
                  "type": "integer",
                  "minimum": 0
                },
                "high_precision_hostname_patterns": {
                  "type": "integer",
                  "minimum": 0
                },
                "host_artifacts": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "additionalProperties": false
            },
            "notes": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk_titles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_status": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
